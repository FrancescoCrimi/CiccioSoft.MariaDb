--file
../include/mysql.h


--output
../Native

--namespace
CiccioSoft.Interop.MariaDb.Native

--libraryPath
libmariadb

--methodClassName
MySqlNative

--language
c

--with-access-specifier
*=internal
MySqlOption=public
MySqlFieldTypes=public

--exclude
MARIADB_X509_INFO
ma_charset_info_st
mysql_fetch_field
st_mysql
st_mysql_stmt
st_mysql_res

--remap
enum_field_types=MySqlFieldTypes
ma_charset_info_st*=nint
mysql_fetch_field*=nint
mysql_option=MySqlOption
st_mysql*=nint
st_mysql_bind=MySqlBindNative
st_mysql_stmt*=nint
st_mysql_field=MySqlFieldNative
st_mysql_res*=nint
MYSQL_ROW=nint
char=byte

--config
multi-file
generate-helper-types
generate-macro-bindings
