--file
../include/mysql.h
--traverse
../include/mariadb_version.h
--output
../Native
--namespace
CiccioSoft.Data.MariaDbEmbedded.Interop.Native
--libraryPath
libmariadb
--methodClassName
NativeVersion
--language
c
--with-access-specifier
*=internal
MySqlOption=public
--exclude
MARIADB_X509_INFO
ma_charset_info_st
mysql_fetch_field
st_mysql
st_mysql_stmt
st_mysql_field
st_mysql_res
--remap
ma_charset_info_st*=nint
mysql_fetch_field*=nint
mysql_option=MySqlOption
st_mysql*=nint
st_mysql_stmt*=nint
st_mysql_field*=nint
st_mysql_res*=nint
char=byte
--config
multi-file
generate-helper-types
generate-macro-bindings
