--file
./include/mysql.h
--traverse
./include/mariadb_stmt.h
--output
Native
--namespace
CiccioSoft.Data.MariaDbEmbedded.Interop.Native
--libraryPath
libmariadb
--methodClassName
NativeMariadbStmt
--language
c
--with-access-specifier
*=internal
--remap
ma_charset_info_st*=nint
mysql_fetch_field*=nint
st_mysql*=nint
st_mysql_stmt*=nint
st_mysql_field=nint
st_mysql_res=nint
char=byte
--config
multi-file
generate-helper-types
generate-macro-bindings
