--file
./include/mysql.h
--output
Native
--namespace
CiccioSoft.Data.MariaDbEmbedded.Interop.Native
--libraryPath
libmariadb
--methodClassName
NativeMysql
--language
c
--with-access-specifier
*=internal
--exclude
st_mysql
st_mysql_stmt
ma_charset_info_st
mysql_fetch_field
st_mysql_field
st_mysql_res
--remap
st_mysql*=nint
st_mysql_stmt*=nint
ma_charset_info_st*=nint
mysql_fetch_field*=nint
st_mysql_field=nint
st_mysql_res=nint
char=byte
--config
multi-file
generate-helper-types
generate-macro-bindings
