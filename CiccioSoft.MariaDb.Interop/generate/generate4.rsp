--file
../include/mysql.h
--traverse
../include/mariadb_ctype.h
--output
../Native

--namespace
CiccioSoft.MariaDb.Interop.Native

--libraryPath
libmariadb

--methodClassName
MariadbCTypeNative

--language
c

--with-access-specifier
*=internal
MySqlOption=public
MySqlFieldTypes=public

--exclude
MARIADB_X509_INFO
ma_charset_info_st
mysql_fetch_field
st_mysql
st_mysql_res
st_mysql_stmt

--remap
enum_field_types=MySqlFieldTypes
ma_charset_info_st*=nint
mysql_fetch_field*=nint
mysql_option=MySqlOption
st_mysql*=nint
st_mysql_bind=MySqlBindNative
st_mysql_field=MySqlFieldNative
st_mysql_res*=nint
st_mysql_stmt*=nint
MYSQL_ROW=nint
char=byte

--config
multi-file
generate-helper-types
generate-macro-bindings
