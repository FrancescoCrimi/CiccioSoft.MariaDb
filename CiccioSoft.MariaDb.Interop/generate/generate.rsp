--file
../include/mysql.h


--output
../Native

--namespace
CiccioSoft.MariaDb.Interop.Native

--libraryPath
libmariadb

--methodClassName
MySqlNative

--language
c

--with-access-specifier
*=internal
MySqlOption=public
MySqlFieldTypes=public

--exclude
MARIADB_X509_INFO
ma_charset_info_st
mysql_fetch_field
st_mysql
st_mysql_res
st_mysql_stmt
MARIADB_FIELD_ATTR_LAST
unknown_sqlstate
IS_PRI_KEY
IS_NOT_NULL
IS_BLOB
IS_NUM
IS_NUM_FIELD
INTERNAL_NUM_FIELD
SET_CLIENT_ERROR
set_mariadb_error
CLEAR_CLIENT_ERROR
mysql_reload
mariadb_connect

--remap
enum_field_types=MySqlFieldTypes
ma_charset_info_st*=nint
mysql_fetch_field*=nint
mysql_option=MySqlOption
st_mysql*=nint
st_mysql_bind=MySqlBindNative
st_mysql_field=MySqlFieldNative
st_mysql_res*=nint
st_mysql_stmt*=nint
MYSQL_ROW=nint
char=byte

--config
multi-file
generate-helper-types
generate-macro-bindings
